      "index": "at",
      "roundness": null,
      "seed": 406669654,
      "version": 907,
      "versionNonce": 739857308,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776661293280,
      "link": null,
      "locked": false,
      "text": "State:\n1. ErrorEmployees\n2. PendingEmployees\n3. EmployeesList\n4. Message of deleting employee\n5. Full name filter\n6. Department filter\n7. Email filter\n8. Position filter\n9. Only Overtime filter\n10. Sorting value\n11. Sorting type\n12. Full name E \n13. Department E\n14. Email E\n15. Position E\n16. Add - can or no click\n17. All employees\n18. All overtime employees\n19. All planned hours\n20. All actual hours\n21. Recent watched employees NO\n22. Recent watched employees list",
      "fontSize": 20.83478260869569,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "State:\n1. ErrorEmployees\n2. PendingEmployees\n3. EmployeesList\n4. Message of deleting employee\n5. Full name filter\n6. Department filter\n7. Email filter\n8. Position filter\n9. Only Overtime filter\n10. Sorting value\n11. Sorting type\n12. Full name E \n13. Department E\n14. Email E\n15. Position E\n16. Add - can or no click\n17. All employees\n18. All overtime employees\n19. All planned hours\n20. All actual hours\n21. Recent watched employees NO\n22. Recent watched employees list",
      "autoResize": false,
